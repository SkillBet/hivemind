# ============================================================================
# ShadowNode Environment Configuration
# Copy to `.env.local` and fill in real values. All keys are optional for the
# MVP — the app degrades gracefully to a simulated TEE + SQLite when unset.
# ============================================================================

# ---- AI Provider -----------------------------------------------------------
# Optional. When unset, the chat endpoint returns a deterministic mock response
# so the encryption flow can be demonstrated without external calls.
OPENROUTER_API_KEY=sk-or-v1-your_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model id passed to OpenRouter when the client omits one.
DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# ---- TEE Enclave -----------------------------------------------------------
# Real TEE endpoints (V2). When TEE_INFERENCE_URL is unset, the chat route uses
# the OpenRouter fallback (or mock) and performs server-side encrypt/decrypt to
# emulate the enclave boundary for the MVP.
TEE_ATTESTATION_URL=https://your-tee-enclave.com/attestation
TEE_INFERENCE_URL=https://your-tee-enclave.com/inference
# PEM-encoded RSA public key the enclave uses to receive sealed prompts.
# Generate a sample pair with `npm run tee:genkey`. Leave blank to auto-generate
# an ephemeral dev key on first server boot (persisted to .tee-dev-key.json).
TEE_PUBLIC_KEY_PEM=

# ---- Blockchain (Base mainnet) --------------------------------------------
NEXT_PUBLIC_USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_SUBSCRIPTION_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CHAIN_ID=8453

# ---- Database --------------------------------------------------------------
# MVP default: local SQLite file (zero setup). For Postgres, comment this in:
# DATABASE_URL=postgresql://user:pass@localhost:5432/shadownode
DATABASE_URL=file:./dev.db

# ---- Stripe (fiat subscriptions) ------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Price IDs created in the Stripe dashboard for Pro / Enterprise monthly.
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# ---- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Turn on to force the simulated TEE path even if real endpoints are set.
SHADOWNODE_SIMULATE_TEE=1
